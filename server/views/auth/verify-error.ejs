<!doctype html>
<html lang="vi">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    <%= title %>
  </title>
  <meta name="robots" content="noindex" />
  <style>
    :root {
      --bg: #0b1220;
      --card: #0f172a;
      --err: #ef4444;
      --text: #e5e7eb;
      --muted: #94a3b8;
      --btn: #334155
    }

    * {
      box-sizing: border-box
    }

    body {
      margin: 0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background: radial-gradient(1200px 600px at 110% -10%, #1e293b 0%, transparent 60%), linear-gradient(180deg, #0b1220, #0b1220);
      color: var(--text)
    }

    .wrap {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 24px
    }

    .card {
      width: 100%;
      max-width: 520px;
      background: linear-gradient(180deg, #0f172a, #0b1220);
      border: 1px solid rgba(148, 163, 184, .14);
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 10px 50px rgba(0, 0, 0, .35)
    }

    .icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: rgba(239, 68, 68, .12);
      border: 1px solid rgba(239, 68, 68, .35);
      color: var(--err);
      margin-bottom: 12px
    }

    h1 {
      margin: 0 0 8px;
      font-size: 22px
    }

    p {
      margin: 0 0 18px;
      color: var(--muted);
      line-height: 1.6
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap
    }

    a.btn {
      display: inline-block;
      text-decoration: none;
      padding: 10px 16px;
      border-radius: 10px;
      border: 1px solid rgba(148, 163, 184, .2);
      background: linear-gradient(180deg, #1f2937, #0f172a);
      color: #fff
    }
  </style>
</head>

<body>
  <div class="wrap">
    <div class="card">
      <div class="icon">!</div>
      <h1>
        <%= headline %>
      </h1>
      <p>
        <%= message %>
      </p>
      <div class="actions">
        <a class="btn" href="<%= homeUrl %>">Về trang chủ</a>
      </div>
    </div>
  </div>
</body>

</html>